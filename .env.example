# Google Sheets
GOOGLE_SHEETS_ID=your_spreadsheet_id_here
GOOGLE_SHEET_NAME=Properties
GOOGLE_CREDENTIALS_PATH=credentials/service_account.json

# Facebook
FACEBOOK_EMAIL=your_email@example.com
FACEBOOK_PASSWORD=your_password_here
FACEBOOK_GROUP_URL=https://www.facebook.com/groups/your_group_id

# Browser session (persistent login)
BROWSER_USER_DATA_DIR=cookies/facebook_session
COOKIES_PATH=cookies/facebook_cookies.json

# Posting behavior
POST_INTERVAL_MINUTES=120
MAX_POSTS_PER_RUN=3
HEADLESS=false

# Image cache
IMAGE_CACHE_DIR=data/images

# LINE OA bot (Messaging API)
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_BOT_HOST=0.0.0.0
LINE_BOT_PORT=8787
# 0 = ไม่ตอบลูกค้าอัตโนมัติ (โหมด ops/ฟอโล่ว) | 1 = เปิด OpenAI auto-reply
LINE_AUTO_REPLY=0
# แจ้งกลุ่มแอดมินเมื่อมีแชทลูกค้ารอตอบ
LINE_OPS_ALERT_LIVE=1
# Group ID ของกลุ่มคุณ+แอดมิน (ขึ้นต้นด้วย C...)
LINE_OPS_GROUP_ID=
# (ทางเลือก) user id แอดมินที่สั่งงานผ่าน DM ได้ คั่นด้วย comma
LINE_ADMIN_USER_IDS=

# (แนะนำ) ngrok ฟรี — นิ่งกว่า Cloudflare quick tunnel ตอนรันบน Mac
# ได้จาก https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# OpenAI (reuse key from LivingBKK_App if you already have one)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
