# Google Sheets
# ซิงค์กลับแอป → ชีททดลอง
# GOOGLE_SHEETS_ID=trial_spreadsheet_id
# HUB_GOOGLE_SHEETS_ID=trial_spreadsheet_id
# HUB_SHEET_GID=1229880098
# HUB_SHEET_NAME=ทรัพย์ Hub
# HUB_OVERVIEW_SHEET_NAME=ทรัพย์รวม
# (ทางเลือก) HUB_OVERVIEW_SHEET_GID=... ถ้าแท็บถูกเปลี่ยนชื่อ

# ดึงเข้าแอป ← ชีทจริง
# SOURCE_GOOGLE_SHEETS_ID=production_spreadsheet_id
# MAIN_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/XXXX/export?format=csv&gid=0
# WAIT_POST_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/XXXX/gviz/tq?tqx=out:csv&sheet=รอโพสต์
# บน Render: เปิด sync ตอนบูตอัตโนมัติเมื่อมี URL/ID ด้านบน (disk ephemeral หลัง redeploy)
# HUB_STARTUP_SHEET_SYNC=1

GOOGLE_SHEETS_ID=your_spreadsheet_id_here
GOOGLE_SHEET_NAME=Properties
GOOGLE_CREDENTIALS_PATH=credentials/service_account.json

# Facebook
FACEBOOK_EMAIL=your_email@example.com
FACEBOOK_PASSWORD=your_password_here
FACEBOOK_GROUP_URL=https://www.facebook.com/groups/your_group_id

# Browser session (persistent login)
BROWSER_USER_DATA_DIR=cookies/facebook_session
COOKIES_PATH=cookies/facebook_cookies.json

# Posting behavior
POST_INTERVAL_MINUTES=120
MAX_POSTS_PER_RUN=3
HEADLESS=false

# Image cache
IMAGE_CACHE_DIR=data/images

# LINE OA bot (Messaging API)
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_BOT_HOST=0.0.0.0
LINE_BOT_PORT=8787
# 0 = ไม่ตอบลูกค้าอัตโนมัติ (โหมด ops/ฟอโล่ว) | 1 = เปิด OpenAI auto-reply
LINE_AUTO_REPLY=0
# แจ้งกลุ่มแอดมินเมื่อมีแชทลูกค้ารอตอบ
LINE_OPS_ALERT_LIVE=1
# Group ID ของกลุ่มคุณ+แอดมิน (ขึ้นต้นด้วย C...)
LINE_OPS_GROUP_ID=
# (ทางเลือก) user id แอดมินที่สั่งงานผ่าน DM ได้ คั่นด้วย comma
LINE_ADMIN_USER_IDS=

# (แนะนำ) ngrok ฟรี — นิ่งกว่า Cloudflare quick tunnel ตอนรันบน Mac
# ได้จาก https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# OpenAI (reuse key from LivingBKK_App if you already have one)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# เขียนกลับชีททดลอง (เลือกอย่างใดอย่างหนึ่ง):
# HUB_SHEET_WEBAPP_URL=https://script.google.com/macros/s/XXXX/exec
# หรือ GOOGLE_SERVICE_ACCOUNT_JSON={...ทั้งก้อน JSON...} + แชร์ชีทให้ client_email เป็น Editor
# (production บน Render ต้องตั้ง GOOGLE_SERVICE_ACCOUNT_JSON — CSV publish URL ใช้ได้อ่านอย่างเดียว)
# ชั่วคราวดาวน์โหลด: GET /api/properties/overview-export.csv
